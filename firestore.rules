rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, list: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin();
      allow create: if request.auth != null;
    }
    
    // Outlet Rules
    match /outlets/{outletId} {
      // Helper for role checks
      function hasRole(role) {
        return request.auth != null && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
      }

      // 1. Admin can do everything
      allow read, write: if isAdmin();
      
      // 2. Enumeration Staff can create, read, and update THEIR OWN entries
      allow create: if hasRole('enumeration');
      allow read: if hasRole('enumeration') || hasRole('onboarding');
      allow update: if hasRole('enumeration') && 
        resource.data.fieldOfficerUid == request.auth.uid &&
        request.resource.data.status == 'enumerated'; // Can only edit while in enumeration stage
      
      // 3. Onboarding Staff can read and update (for cross-checking and activation)
      allow update: if hasRole('onboarding') && 
        request.resource.data.diff(resource.data).affectedKeys()
           .hasAny([
             'status', 'onboardingChecklist', 'activationDetails', 'updatedAt',
             'recommendedClass', 'recommendedAction', 'supervisorReview', 'managementApproval',
             'route', 'firstSupplyDate', 'approvedCreditLimit', 'physicalDocumentSigned'
           ]);
    }
  }
}
